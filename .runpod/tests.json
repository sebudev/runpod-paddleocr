{
  "tests": [
    {
      "name": "basic_ocr_demo",
      "input": {
        "image": "https://paddle-model-ecology.bj.bcebos.com/paddlex/imgs/demo_image/paddleocr_vl_demo.png",
        "tasks": "auto",
        "output_format": "json"
      },
      "timeout": 120000
    },
    {
      "name": "markdown_output",
      "input": {
        "image": "https://paddle-model-ecology.bj.bcebos.com/paddlex/imgs/demo_image/paddleocr_vl_demo.png",
        "output_format": "markdown"
      },
      "timeout": 120000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA RTX A4500",
    "gpuCount": 1,
    "env": [
      {
        "key": "PIPELINE_VERSION",
        "value": "v1.6"
      },
      {
        "key": "DEFAULT_TASKS",
        "value": "auto"
      },
      {
        "key": "OUTPUT_FORMAT",
        "value": "json"
      },
      {
        "key": "MAX_NEW_TOKENS",
        "value": "512"
      }
    ],
    "allowedCudaVersions": [
      "12.8", "12.7", "12.6", "12.5", "12.4",
      "12.3", "12.2", "12.1", "12.0", "11.8"
    ]
  }
}
